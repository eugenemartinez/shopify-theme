# ── System / OS ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Dependencies ──────────────────────────────────────
# Kills node_modules in root, liquid, react, and theme folders
node_modules
**/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Build Outputs ─────────────────────────────────────
# Ignore the React dist folders and compiled assets
dist
build
**/dist
**/build
.cache
.parcel-cache

# Ignore the compiled JS bundles specifically
# Adjust these paths if your bundle names differ
shopify-gsap/assets/js/bundle.js
shopify-motion/assets/js/bundle.js

# ── Shopify Specific ──────────────────────────────────
# CLI internal state and metadata
.shopify/

# Never commit local theme settings (prevents overwriting prod)
**/config/settings_data.json

# Ignore zip backups created by 'shopify theme share'
*.zip
**/release/

# ── Environment & Config ──────────────────────────────
.env
.env.*
!.env.example

# ── Editor ────────────────────────────────────────────
# Clean workspace for AstroNvim / VSCode
.nvim/
.vscode/*
!.vscode/extensions.json
.idea
*.swp
*.swo
Session.vim

# ── Logs ──────────────────────────────────────────────
logs
*.log
