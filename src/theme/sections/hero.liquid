<section
  id="hero"
  class="full-width relative flex min-h-screen w-full items-center overflow-hidden"
  style="background: var(--background);"
>
  {%- # Background image -%}
  {%- if section.settings.bg_image != blank -%}
    <div class="absolute inset-0 z-0">
      <img
        src="{{ section.settings.bg_image | image_url: width: 1920 }}"
        alt=""
        class="h-full w-full object-cover"
        loading="eager"
      >
      <div
        class="absolute inset-0"
        style="background: color-mix(in oklab, var(--background) {{ section.settings.overlay_opacity }}%, transparent);"
      ></div>
    </div>
  {%- endif -%}

  {%- # Decorative blobs -%}
  {%- if section.settings.show_blobs -%}
    <div
      class="pointer-events-none absolute -top-32 -left-32 h-96 w-96 rounded-full opacity-20 blur-3xl"
      style="background: var(--foreground);"
      data-gsap="blob"
      data-duration="12"
      data-scale="1.3"
      data-x="40"
      data-y="30"
    ></div>
    <div
      class="pointer-events-none absolute -right-32 -bottom-32 h-96 w-96 rounded-full opacity-10 blur-3xl"
      style="background: var(--foreground);"
      data-gsap="blob"
      data-duration="16"
      data-scale="1.2"
      data-x="-30"
      data-y="-20"
    ></div>
  {%- endif -%}

  {%- # Main flex container: content left, illustration right -%}
  <div class="relative z-10 flex w-full justify-center px-6 py-32">
    <div class="flex max-w-[var(--page-width)] flex-col items-center justify-center gap-12 md:flex-row md:gap-16">
      {%- # Content left -%}
      <div class="max-w-3xl flex-1 {{ section.settings.content_align }} flex flex-col gap-6">
        {%- if section.settings.eyebrow != blank -%}
          <p
            class="text-foreground/50 text-xs font-semibold tracking-widest uppercase"
            data-gsap="fade-up"
            data-delay="0.1"
          >
            {{ section.settings.eyebrow }}
          </p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1
            class="text-foreground text-5xl font-bold tracking-tight md:text-6xl lg:text-7xl"
            style="font-family: var(--font-headline);"
            data-gsap="fade-up"
            data-delay="0.2"
          >
            {{ section.settings.heading }}
          </h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p
            class="text-foreground/60 max-w-xl text-lg leading-relaxed"
            data-gsap="fade-up"
            data-delay="0.35"
          >
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}

        {%- # Buttons -%}
        <div class="flex flex-wrap items-center gap-4 md:gap-6" data-gsap="fade-up" data-delay="0.5">
          {%- if section.settings.btn1_label != blank -%}
            <a
              href="{{ section.settings.btn1_url }}"
              class="inline-flex items-center gap-2 px-8 py-4 text-sm font-semibold transition-all duration-200 hover:opacity-80 md:text-base"
              style="background: var(--primary); color: var(--primary-foreground); border-radius: var(--radius);"
              data-gsap="hover-lift"
            >
              {{ section.settings.btn1_label }}
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                data-arrow
              >
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.btn2_label != blank -%}
            <a
              href="{{ section.settings.btn2_url }}"
              class="inline-flex items-center gap-2 px-8 py-4 text-sm font-semibold transition-all duration-200 hover:opacity-80 md:text-base"
              style="background: transparent; color: var(--foreground); border: 1px solid var(--border); border-radius: var(--radius);"
              data-gsap="hover-lift"
            >
              {{ section.settings.btn2_label }}
            </a>
          {%- endif -%}
        </div>

        {%- # Trust badges -%}
        {%- if section.settings.show_trust -%}
          <div class="mt-6 flex flex-wrap items-center gap-4 md:gap-6" data-gsap="fade-up" data-delay="0.65">
            {%- assign trust_items = section.settings.trust_text | split: '|' -%}
            {%- for item in trust_items -%}
              <div class="text-foreground/40 flex items-center gap-2 text-xs">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {{ item | strip }}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- # Right-side abstract illustration -%}
      <div
        class="pointer-events-none flex w-full max-w-[400px] flex-1 justify-center md:justify-end"
        data-gsap="fade-in"
        data-delay="0.4"
      >
        <svg class="w-64 md:w-full" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
          <circle cx="100" cy="100" r="80" fill="rgba(56,189,248,0.25)" data-gsap="float" data-y="-15" data-duration="6"/>
          <circle cx="140" cy="60" r="50" fill="rgba(236,72,153,0.25)" data-gsap="wiggle" data-y="-10" data-duration="4"/>
          <polygon points="60,160 90,110 30,110" fill="rgba(34,197,94,0.25)" data-gsap="blob" data-duration="5"/>
          <path d="M30 70 Q60 20, 100 60 T170 80 Q140 140, 100 120 T30 70" fill="rgba(250,204,21,0.15)" data-gsap="float" data-y="-12" data-duration="7"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- end main flex container -->

  {%- # Scroll indicator -%}
  {%- if section.settings.show_scroll_indicator -%}
    <div class="absolute bottom-8 left-1/2 flex -translate-x-1/2">
      <div
        class="flex flex-col items-center gap-2"
        data-gsap="float"
        data-y="-15"
        data-duration="1.5"
      >
        <span class="text-foreground/30 text-xs tracking-widest uppercase">Scroll</span>
        <div class="from-foreground h-8 w-px bg-gradient-to-b to-transparent opacity-20"></div>
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "site-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "New Collection"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted for the ones who care."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Timeless pieces made with intention. Designed to last."
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content Alignment",
      "options": [
        { "value": "text-left items-start", "label": "Left" },
        { "value": "text-center items-center mx-auto", "label": "Center" },
        { "value": "text-right items-end ml-auto", "label": "Right" }
      ],
      "default": "text-left items-start"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Primary Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Primary Button URL",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Secondary Button Label"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "Secondary Button URL"
    },
    {
      "type": "header",
      "content": "Trust Badges"
    },
    {
      "type": "checkbox",
      "id": "show_trust",
      "label": "Show Trust Badges",
      "default": true
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust Items (separate with |)",
      "default": "Free Shipping | Easy Returns | Secure Checkout"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "show_blobs",
      "label": "Show Decorative Blobs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show Scroll Indicator",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
