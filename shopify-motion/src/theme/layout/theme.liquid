<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {% render 'css-variables' %}

    {% unless settings.font_primary.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
      {{ settings.font_primary | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'index.css'    | asset_url | stylesheet_tag }}

    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

<body class="{% if settings.dark_mode %}dark {% endif %}bg-background text-foreground min-h-screen" data-motion="fade-in">
    {% sections 'header-group' %}

    <main>
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    <script src="{{ 'index.js' | asset_url }}" defer></script>
  </body>
</html>
