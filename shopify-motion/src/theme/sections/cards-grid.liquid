{%- if section.settings.bg == 'alt' -%}
  {%- assign section_bg = 'var(--secondary)' -%}
{%- else -%}
  {%- assign section_bg = 'var(--background)' -%}
{%- endif -%}

<section
  id="cards-grid-{{ section.id }}"
  class="full-width flex w-full flex-col items-center py-20"
  style="background: {{ section_bg }};"
>
  <div class="flex w-full max-w-7xl flex-col items-center gap-12 px-6">
    {%- # Section header -%}
    {%- if section.settings.eyebrow != blank
      or section.settings.heading != blank
      or section.settings.subheading != blank
    -%}
      <div class="flex flex-col items-center gap-4 text-center">
        {%- if section.settings.eyebrow != blank -%}
          <p
            class="text-foreground/40 text-xs font-semibold tracking-widest uppercase"
            data-motion="fade-up"
            data-scroll="true"
            data-delay="0.1"
          >
            {{ section.settings.eyebrow }}
          </p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2
            class="text-foreground text-4xl leading-tight font-bold tracking-tight md:text-5xl"
            style="font-family: var(--font-headline);"
            data-motion="fade-up"
            data-scroll="true"
            data-delay="0.2"
          >
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p
            class="text-foreground/50 text-lg"
            data-motion="fade-up"
            data-scroll="true"
            data-delay="0.3"
          >
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- # Cards grid -%}
    <div
      class="grid grid-cols-1 gap-8 md:grid-cols-2 {{ section.settings.columns }}"
      data-motion="stagger-fade-up"
      data-scroll="true"
      data-stagger="0.1"
    >
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'card' -%}
            <div
              class="bg-card border-border flex flex-col gap-4 rounded-[var(--radius)] border p-8"
              data-motion="hover-card"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.icon != 'none' -%}
                <div class="bg-accent flex h-10 w-10 items-center justify-center rounded-[var(--radius)]">
                  {%- case block.settings.icon -%}
                    {%- when 'star' -%}
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                      >
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                      </svg>
                  {%- endcase -%}
                </div>
              {%- endif -%}

              {%- if block.settings.image != blank -%}
                <div class="overflow-hidden rounded-[var(--radius)]">
                  <img
                    src="{{ block.settings.image | image_url: width: 600 }}"
                    alt="{{ block.settings.image.alt | escape }}"
                    class="w-full object-cover transition-transform duration-500 hover:scale-105"
                    style="aspect-ratio:16/9;"
                    loading="lazy"
                  >
                </div>
              {%- endif -%}

              {%- if block.settings.heading != blank -%}
                <h3 class="text-foreground text-lg font-semibold" style="font-family: var(--font-headline);">
                  {{ block.settings.heading }}
                </h3>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <p class="text-foreground/50 text-sm leading-relaxed">
                  {{ block.settings.text }}
                </p>
              {%- endif -%}

              {%- if block.settings.link_label != blank -%}
                <a
                  href="{{ block.settings.link_url }}"
                  class="text-foreground mt-auto inline-flex items-center gap-1 text-sm font-medium transition-opacity duration-200 hover:opacity-60"
                  data-motion="hover-arrow"
                >
                  {{- block.settings.link_label -}}
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    data-arrow
                  >
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- # Bottom CTA -%}
    {%- assign btn_label = section.settings.btn_label | default: 'Learn More' -%}
    {%- assign btn_url = section.settings.btn_url | default: '/' -%}
    <div class="mt-12 flex justify-center" data-motion="fade-up" data-scroll="true">
      <a
        href="{{ btn_url }}"
        class="inline-flex items-center gap-2 px-7 py-3.5 text-sm font-semibold transition-all duration-200 hover:opacity-80"
        style="background: var(--primary); color: var(--primary-foreground); border-radius: var(--radius);"
        data-motion="hover-lift"
      >
        {{ btn_label }}
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          data-arrow
        >
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cards Grid",
  "tag": "section",
  "class": "site-cards-grid-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Why choose us."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you need, nothing you don't."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (Desktop)",
      "options": [
        { "value": "lg:grid-cols-2", "label": "2 Columns" },
        { "value": "lg:grid-cols-3", "label": "3 Columns" },
        { "value": "lg:grid-cols-4", "label": "4 Columns" }
      ],
      "default": "lg:grid-cols-3"
    },
    {
      "type": "select",
      "id": "bg",
      "label": "Background",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "alt", "label": "Alternate" }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "Bottom CTA"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "star", "label": "Star" },
            { "value": "heart", "label": "Heart" },
            { "value": "check", "label": "Checkmark" },
            { "value": "shield", "label": "Shield" },
            { "value": "truck", "label": "Truck" },
            { "value": "refresh", "label": "Returns" },
            { "value": "lock", "label": "Lock" },
            { "value": "zap", "label": "Zap" }
          ],
          "default": "star"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image (optional)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Card Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "A short description of this feature or benefit."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Label"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cards Grid",
      "blocks": [{ "type": "card" }, { "type": "card" }, { "type": "card" }]
    }
  ]
}
{% endschema %}
