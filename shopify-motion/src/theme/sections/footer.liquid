<footer
  id="site-footer"
  class="border-border w-full border-t"
  style="background: var(--background);"
  data-footer
>
  {%- # Main footer content -%}
  <div
    class="px-6 py-16"
    style="max-width: var(--page-width); margin-inline: auto;"
  >
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4">
      {%- # Brand column -%}
      <div class="lg:col-span-2" data-motion="fade-up" data-scroll="true" data-scroll-start="top 95%">
        <a href="/" class="mb-4 inline-block" data-motion="hover-scale">
          {%- if section.settings.footer_logo != blank -%}
            <img
              src="{{ section.settings.footer_logo | image_url: width: 160 }}"
              alt="{{ shop.name }}"
              width="120"
              height="40"
              class="h-8 w-auto object-contain"
            >
          {%- else -%}
            <span
              class="text-foreground text-lg font-bold"
              style="font-family: var(--font-headline);"
            >
              {{ shop.name }}
            </span>
          {%- endif -%}
        </a>

        {%- if section.settings.footer_desc != blank -%}
          <p class="text-muted-foreground mb-6 max-w-sm text-sm leading-relaxed">
            {{ section.settings.footer_desc }}
          </p>
        {%- endif -%}

        {%- # Social links -%}
        <div class="flex items-center gap-4">
          {%- if settings.social_instagram != blank -%}
            <a
              href="{{ settings.social_instagram }}"
              class="text-foreground/40 hover:text-foreground transition-colors duration-200"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
              data-motion="hover-scale"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a
              href="{{ settings.social_facebook }}"
              class="text-foreground/40 hover:text-foreground transition-colors duration-200"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
              data-motion="hover-scale"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if settings.social_twitter != blank -%}
            <a
              href="{{ settings.social_twitter }}"
              class="text-foreground/40 hover:text-foreground transition-colors duration-200"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Twitter / X"
              data-motion="hover-scale"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
            <a
              href="{{ settings.social_tiktok }}"
              class="text-foreground/40 hover:text-foreground transition-colors duration-200"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="TikTok"
              data-motion="hover-scale"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if settings.social_youtube != blank -%}
            <a
              href="{{ settings.social_youtube }}"
              class="text-foreground/40 hover:text-foreground transition-colors duration-200"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="YouTube"
              data-motion="hover-scale"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- # Nav column 1 -%}
      {%- if section.settings.nav1_title != blank or section.settings.nav1_menu != blank -%}
        <div data-motion="fade-up" data-scroll="true" data-delay="0.1" data-scroll-start="top 95%">
          <h4
            class="text-foreground mb-4 text-sm font-semibold tracking-widest uppercase"
            style="font-family: var(--font-headline);"
          >
            {{ section.settings.nav1_title | default: 'Links' }}
          </h4>
          <ul class="flex flex-col gap-3">
            {%- for link in section.settings.nav1_menu.links -%}
              <li>
                <a
                  href="{{ link.url }}"
                  class="text-muted-foreground hover:text-foreground text-sm transition-colors duration-200"
                  data-motion="hover-dim"
                >
                  {{- link.title -}}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      {%- # Nav column 2 -%}
      {%- if section.settings.nav2_title != blank or section.settings.nav2_menu != blank -%}
        <div data-motion="fade-up" data-scroll="true" data-delay="0.2" data-scroll-start="top 95%">
          <h4
            class="text-foreground mb-4 text-sm font-semibold tracking-widest uppercase"
            style="font-family: var(--font-headline);"
          >
            {{ section.settings.nav2_title | default: 'Info' }}
          </h4>
          <ul class="flex flex-col gap-3">
            {%- for link in section.settings.nav2_menu.links -%}
              <li>
                <a
                  href="{{ link.url }}"
                  class="text-muted-foreground hover:text-foreground text-sm transition-colors duration-200"
                  data-motion="hover-dim"
                >
                  {{- link.title -}}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- # Bottom bar -%}
  <div
    class="border-border border-t px-6 py-6"
    style="max-width: var(--page-width); margin-inline: auto;"
  >
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-muted-foreground text-xs">
        {%- if section.settings.footer_copyright != blank -%}
          {{ section.settings.footer_copyright }}
        {%- else -%}
          &copy; {{ 'now' | date: '%Y' }}
          {{ shop.name }}. All rights reserved.
        {%- endif -%}
      </p>

      {%- # Payment icons -%}
      {%- if section.settings.show_payment_icons -%}
        <div class="flex items-center gap-2">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'h-6 w-auto opacity-40' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "site-footer-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer Logo"
    },
    {
      "type": "textarea",
      "id": "footer_desc",
      "label": "Brand Description",
      "default": "Quality products crafted with care."
    },
    {
      "type": "header",
      "content": "Navigation Column 1"
    },
    {
      "type": "text",
      "id": "nav1_title",
      "label": "Column 1 Title",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "nav1_menu",
      "label": "Column 1 Menu"
    },
    {
      "type": "header",
      "content": "Navigation Column 2"
    },
    {
      "type": "text",
      "id": "nav2_title",
      "label": "Column 2 Title",
      "default": "Info"
    },
    {
      "type": "link_list",
      "id": "nav2_menu",
      "label": "Column 2 Menu"
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "text",
      "id": "footer_copyright",
      "label": "Copyright Text"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ]
}
{% endschema %}
