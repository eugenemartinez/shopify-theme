{%- assign nav = section.settings.menu -%}

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 w-full transition-all duration-300"
  data-header
  data-sticky="{{ section.settings.sticky }}"
>
  <div
    class="flex w-full items-center justify-between px-6 py-4"
    style="max-width: var(--page-width); margin-inline: auto;"
  >
    {%- # Logo -%}

    <a
      href="/"
      class="flex shrink-0 items-center gap-2"
      data-motion="hover-scale"
    >
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 200 }}"
          alt="{{ shop.name }}"
          width="120"
          height="40"
          class="h-10 w-auto object-contain"
        >
      {%- else -%}
        <span
          class="text-foreground text-xl font-bold"
          style="font-family: var(--font-headline);"
        >
          {{ shop.name }}
        </span>
      {%- endif -%}
    </a>

    {%- # Desktop nav -%}
    <nav
      class="hidden shrink-0 items-center gap-8 lg:flex"
      aria-label="Main navigation"
    >
      {%- for link in section.settings.menu.links -%}
        <a
          href="{{ link.url }}"
          class="text-foreground/60 hover:text-foreground relative text-sm font-medium whitespace-nowrap transition-colors duration-200"
          data-motion="hover-dim"
          {% if link.current %}
            aria-current="page"
          {% endif %}
        >
          {{- link.title -}}
        </a>
      {%- endfor -%}
    </nav>

    {%- # Right side — CTA + hamburger -%}
    <div class="flex items-center gap-4">
      {%- # CTA button -%}
      {%- if section.settings.cta_label != blank -%}
        <a
          href="{{ section.settings.cta_url }}"
          class="hidden items-center gap-2 px-5 py-2 text-sm font-semibold transition-all duration-200 hover:opacity-80 lg:inline-flex"
          style="background: var(--primary); color: var(--primary-foreground); border-radius: var(--radius);"
          data-motion="hover-lift"
        >
          {{- section.settings.cta_label -}}
        </a>
      {%- endif -%}

      {%- # Cart icon -%}
      <a
        href="{{ routes.cart_url }}"
        class="text-foreground/60 hover:text-foreground relative flex h-10 w-10 items-center justify-center transition-colors duration-200"
        aria-label="Cart"
        data-motion="hover-scale"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span
            class="absolute -top-1 -right-1 flex h-4 w-4 items-center justify-center text-xs font-bold"
            style="background: var(--primary); color: var(--primary-foreground); border-radius: 9999px;"
            data-cart-count
          >
            {{ cart.item_count }}
          </span>
        {%- endif -%}
      </a>

      {%- # Dark mode toggle -%}
      <button
        id="theme-toggle"
        class="text-foreground/60 hover:text-foreground flex h-10 w-10 cursor-pointer items-center justify-center transition-colors duration-200"
        aria-label="Toggle dark mode"
        data-motion="hover-scale"
      >
        {%- # Sun icon — shown in dark mode -%}
        <svg
          id="icon-sun"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          class="hidden"
        >
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        {%- # Moon icon — shown in light mode -%}
        <svg
          id="icon-moon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          class="hidden"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      {%- # Hamburger -%}
      <button
        id="nav-toggle"
        class="flex h-10 w-10 flex-col items-center justify-center gap-1.5 lg:hidden"
        style="border: 1px solid var(--border); border-radius: var(--radius);"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="bg-foreground h-px w-5 transition-all duration-300" data-bar="top"></span>
        <span class="bg-foreground h-px w-5 transition-all duration-300" data-bar="mid"></span>
        <span class="bg-foreground h-px w-5 transition-all duration-300" data-bar="bot"></span>
      </button>
    </div>
  </div>
</header>

{%- # Mobile menu — fullscreen overlay -%}
<div
  id="mobile-menu"
  class="pointer-events-none fixed inset-0 z-40 flex flex-col items-center justify-center gap-8 opacity-0 transition-all duration-300"
  style="background: var(--background);"
  aria-hidden="true"
>
  <nav
    class="flex flex-col items-center gap-6"
    aria-label="Mobile navigation"
  >
    {%- for link in section.settings.menu.links -%}
      <a
        href="{{ link.url }}"
        class="text-foreground text-3xl font-bold transition-opacity duration-200 hover:opacity-70"
        style="font-family: var(--font-headline);"
        {% if link.current %}
          aria-current="page"
        {% endif %}
      >
        {{- link.title -}}
      </a>
    {%- endfor -%}
  </nav>

  {%- if section.settings.cta_label != blank -%}
    <a
      href="{{ section.settings.cta_url }}"
      class="inline-flex items-center gap-2 px-8 py-3 text-base font-semibold"
      style="background: var(--primary); color: var(--primary-foreground); border-radius: var(--radius);"
    >
      {{- section.settings.cta_label -}}
    </a>
  {%- endif -%}

  {%- # Close button -%}
  <button
    id="nav-close"
    class="text-foreground/60 hover:text-foreground absolute top-6 right-6 flex h-10 w-10 items-center justify-center transition-colors duration-200"
    aria-label="Close menu"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M18 6L6 18M6 6l12 12"/>
    </svg>
  </button>
</div>

{% schema %}
{
  "name": "Header",
  "class": "site-header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL",
      "default": "/collections/all"
    },
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Sticky Header",
      "default": true
    }
  ]
}
{% endschema %}
