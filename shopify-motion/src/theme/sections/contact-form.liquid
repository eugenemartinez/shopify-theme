{%- if section.settings.bg == 'alt' -%}
  {%- assign section_bg = 'var(--secondary)' -%}
{%- else -%}
  {%- assign section_bg = 'var(--background)' -%}
{%- endif -%}

<section
  id="contact-form-{{ section.id }}"
  class="full-width w-full pb-12"
  style="background: {{ section_bg }};"
>
  <div
    class="px-6"
    style="max-width: var(--page-width); margin-inline: auto;"
  >
    <div class="grid grid-cols-1 gap-16 lg:grid-cols-2">
      {%- # Left — info -%}
      <div class="flex flex-col gap-8">
        {%- if section.settings.eyebrow != blank -%}
          <p
            class="text-foreground/40 text-xs font-semibold tracking-widest uppercase"
            data-motion="fade-up"
            data-scroll="true"
            data-delay="0.1"
          >
            {{ section.settings.eyebrow }}
          </p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2
            class="text-foreground text-4xl leading-tight font-bold tracking-tight md:text-5xl"
            style="font-family: var(--font-headline);"
            data-motion="fade-up"
            data-scroll="true"
            data-delay="0.2"
          >
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p
            class="text-foreground/50 text-base leading-relaxed"
            data-motion="fade-up"
            data-scroll="true"
            data-delay="0.3"
          >
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}

        {%- # Contact details -%}
        <div
          class="flex flex-col gap-4"
          data-motion="fade-up"
          data-scroll="true"
          data-delay="0.4"
        >
          {%- if section.settings.email != blank -%}
            <a
              href="mailto:{{ section.settings.email }}"
              class="text-foreground/60 hover:text-foreground flex items-center gap-3 text-sm transition-colors duration-200"
              data-motion="hover-dim"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
              {{ section.settings.email }}
            </a>
          {%- endif -%}

          {%- if section.settings.phone != blank -%}
            <a
              href="tel:{{ section.settings.phone }}"
              class="text-foreground/60 hover:text-foreground flex items-center gap-3 text-sm transition-colors duration-200"
              data-motion="hover-dim"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.29 6.29l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              {{ section.settings.phone }}
            </a>
          {%- endif -%}

          {%- if section.settings.address != blank -%}
            <div class="text-foreground/60 flex items-start gap-3 text-sm">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="mt-0.5 shrink-0"
              >
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              {{ section.settings.address }}
            </div>
          {%- endif -%}
        </div>

        {%- # Social links -%}
        {%- if settings.social_instagram != blank
          or settings.social_facebook != blank
          or settings.social_twitter != blank
        -%}
          <div
            class="flex items-center gap-4 border-t pt-8"
            style="border-color: var(--border);"
            data-motion="fade-up"
            data-scroll="true"
            data-delay="0.5"
          >
            {%- if settings.social_instagram != blank -%}
              <a
                href="{{ settings.social_instagram }}"
                target="_blank"
                rel="noopener noreferrer"
                class="text-foreground/40 hover:text-foreground transition-colors duration-200"
                aria-label="Instagram"
                data-motion="hover-scale"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if settings.social_facebook != blank -%}
              <a
                href="{{ settings.social_facebook }}"
                target="_blank"
                rel="noopener noreferrer"
                class="text-foreground/40 hover:text-foreground transition-colors duration-200"
                aria-label="Facebook"
                data-motion="hover-scale"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if settings.social_twitter != blank -%}
              <a
                href="{{ settings.social_twitter }}"
                target="_blank"
                rel="noopener noreferrer"
                class="text-foreground/40 hover:text-foreground transition-colors duration-200"
                aria-label="Twitter / X"
                data-motion="hover-scale"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- # Right — form -%}
      <div
        data-motion="fade-left"
        data-scroll="true"
        data-delay="0.2"
      >
        {%- form 'contact', id: 'contact-form' -%}
          {%- if form.posted_successfully? -%}
            <div
              class="mb-6 rounded p-4 text-sm"
              style="background: var(--accent); border-radius: var(--radius); color: var(--foreground);"
            >
              {{ section.settings.success_msg | default: 'Thanks for reaching out! We will get back to you soon.' }}
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div
              class="mb-6 p-4 text-sm"
              style="background: color-mix(in oklab, var(--destructive) 10%, transparent); border-radius: var(--radius); color: var(--destructive); border: 1px solid color-mix(in oklab, var(--destructive) 20%, transparent);"
            >
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="flex flex-col gap-5">
            {%- # Name row -%}
            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <div class="flex flex-col gap-2">
                <label
                  for="contact-first-name"
                  class="text-foreground/50 text-xs font-medium tracking-widest uppercase"
                >
                  First Name
                </label>
                <input
                  type="text"
                  id="contact-first-name"
                  name="contact[first_name]"
                  placeholder="John"
                  class="text-foreground placeholder:text-foreground/30 w-full px-4 py-3 text-sm transition-all duration-200 outline-none"
                  style="background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);"
                  data-motion="focus-glow"
                >
              </div>
              <div class="flex flex-col gap-2">
                <label
                  for="contact-last-name"
                  class="text-foreground/50 text-xs font-medium tracking-widest uppercase"
                >
                  Last Name
                </label>
                <input
                  type="text"
                  id="contact-last-name"
                  name="contact[last_name]"
                  placeholder="Doe"
                  class="text-foreground placeholder:text-foreground/30 w-full px-4 py-3 text-sm transition-all duration-200 outline-none"
                  style="background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);"
                  data-motion="focus-glow"
                >
              </div>
            </div>

            {%- # Email -%}
            <div class="flex flex-col gap-2">
              <label
                for="contact-email"
                class="text-foreground/50 text-xs font-medium tracking-widest uppercase"
              >
                Email <span class="text-destructive">*</span>
              </label>
              <input
                type="email"
                id="contact-email"
                name="contact[email]"
                required
                placeholder="john@example.com"
                class="text-foreground placeholder:text-foreground/30 w-full px-4 py-3 text-sm transition-all duration-200 outline-none"
                style="background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);"
                data-motion="focus-glow"
              >
            </div>

            {%- # Phone -%}
            {%- if section.settings.show_phone -%}
              <div class="flex flex-col gap-2">
                <label
                  for="contact-phone"
                  class="text-foreground/50 text-xs font-medium tracking-widest uppercase"
                >
                  Phone
                </label>
                <input
                  type="tel"
                  id="contact-phone"
                  name="contact[phone]"
                  placeholder="+1 (555) 000-0000"
                  class="text-foreground placeholder:text-foreground/30 w-full px-4 py-3 text-sm transition-all duration-200 outline-none"
                  style="background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);"
                  data-motion="focus-glow"
                >
              </div>
            {%- endif -%}

            {%- # Subject -%}
            {%- if section.settings.show_subject -%}
              <div class="flex flex-col gap-2">
                <label
                  for="contact-subject"
                  class="text-foreground/50 text-xs font-medium tracking-widest uppercase"
                >
                  Subject
                </label>
                <input
                  type="text"
                  id="contact-subject"
                  name="contact[subject]"
                  placeholder="How can we help?"
                  class="text-foreground placeholder:text-foreground/30 w-full px-4 py-3 text-sm transition-all duration-200 outline-none"
                  style="background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);"
                  data-motion="focus-glow"
                >
              </div>
            {%- endif -%}

            {%- # Message -%}
            <div class="flex flex-col gap-2">
              <label
                for="contact-message"
                class="text-foreground/50 text-xs font-medium tracking-widest uppercase"
              >
                Message <span class="text-destructive">*</span>
              </label>
              <textarea
                id="contact-message"
                name="contact[body]"
                required
                rows="5"
                placeholder="Tell us more..."
                class="text-foreground placeholder:text-foreground/30 w-full resize-none px-4 py-3 text-sm transition-all duration-200 outline-none"
                style="background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);"
                data-motion="focus-glow"
              ></textarea>
            </div>

            {%- # Submit -%}
            <button
              type="submit"
              class="inline-flex w-full cursor-pointer items-center justify-center gap-2 px-7 py-3.5 text-sm font-semibold transition-all duration-200 hover:opacity-80"
              style="background: var(--primary); color: var(--primary-foreground); border-radius: var(--radius);"
              data-motion="hover-lift"
            >
              {{ section.settings.btn_label | default: 'Send Message' }}
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                data-arrow
              >
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </button>
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "tag": "section",
  "class": "site-contact-form-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Contact"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Get in touch."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Have a question or want to work together? We'd love to hear from you."
    },
    {
      "type": "header",
      "content": "Contact Details"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email Address"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address"
    },
    {
      "type": "header",
      "content": "Form Fields"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show Phone Field",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_subject",
      "label": "Show Subject Field",
      "default": true
    },
    {
      "type": "header",
      "content": "Form Messages"
    },
    {
      "type": "text",
      "id": "success_msg",
      "label": "Success Message",
      "default": "Thanks for reaching out! We will get back to you soon."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Send Message"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "bg",
      "label": "Background",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "alt", "label": "Alternate" }
      ],
      "default": "default"
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
