<section id="related-products" class="w-full py-12" style="background: var(--background);">
  <div
    class="px-6"
    data-motion="fade-up"
    data-scroll="true"
    style="max-width: var(--page-width); margin-inline: auto;"
  >
    {%- if section.settings.heading != blank -%}
      <h2
        class="text-foreground mb-8 pb-6 text-3xl font-bold"
        style="font-family: var(--font-headline);"
      >
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- assign collection_handle = section.settings.collection_handle | default: 'all' -%}
    {%- assign related_collection = collections[collection_handle] -%}

    {%- if related_collection != null and related_collection.products_count > 0 -%}
      <div class="grid gap-6 {{ section.settings.columns }}">
        {%- for product in related_collection.products limit: section.settings.limit -%}
          <div class="bg-card flex flex-col gap-3 rounded border p-4">
            <a href="{{ product.url }}">
              <img
                src="{{ product.featured_image | image_url: width: 400 }}"
                alt="{{ product.title }}"
                class="h-48 w-full rounded object-cover"
              >
            </a>
            <a href="{{ product.url }}" class="text-foreground mt-2 font-semibold">{{ product.title }}</a>
            <span class="text-foreground/60">{{ product.price | money }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="text-foreground/50 text-center">No products to display.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Related Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Products you may like"
    },
    {
      "type": "text",
      "id": "collection_handle",
      "label": "Collection handle",
      "default": "all"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "default": "grid-cols-2",
      "options": [
        { "value": "grid-cols-2", "label": "2 columns" },
        { "value": "grid-cols-3", "label": "3 columns" },
        { "value": "grid-cols-4", "label": "4 columns" }
      ]
    },
    {
      "type": "number",
      "id": "limit",
      "label": "Number of products to show"
    }
  ]
}
{% endschema %}
