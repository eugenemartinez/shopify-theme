<div
  class="w-full px-6 py-20 text-center"
  style="max-width: 480px; margin-inline: auto;"
>
  {%- # Logo -%}
  <div
    class="mb-12"
    data-motion="fade-up"
    data-delay="0.1"
  >
    {%- if settings.logo != blank -%}
      <img
        src="{{ settings.logo | image_url: width: 200 }}"
        alt="{{ shop.name }}"
        class="mx-auto h-10 w-auto object-contain"
      >
    {%- else -%}
      <span
        class="text-foreground text-2xl font-bold"
        style="font-family: var(--font-headline);"
      >
        {{ shop.name }}
      </span>
    {%- endif -%}
  </div>

  {%- # Heading -%}
  <div
    class="mb-10 flex flex-col gap-3"
    data-motion="fade-up"
    data-delay="0.2"
  >
    <h1
      class="text-foreground text-4xl font-bold tracking-tight"
      style="font-family: var(--font-headline);"
    >
      {{ section.settings.heading | default: 'Coming Soon' }}
    </h1>
    {%- if section.settings.subheading != blank -%}
      <p class="text-foreground/50 text-base">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}
  </div>

  {%- # Password form -%}
  {%- form 'storefront_password', id: 'password-form' -%}
    {%- if form.errors -%}
      <div
        class="mb-4 p-3 text-center text-sm"
        style="background: color-mix(in oklab, var(--destructive) 10%, transparent); border-radius: var(--radius); color: var(--destructive); border: 1px solid color-mix(in oklab, var(--destructive) 20%, transparent);"
        data-motion="fade-up"
      >
        Wrong password. Please try again.
      </div>
    {%- endif -%}

    <div
      class="flex flex-col gap-3"
      data-motion="fade-up"
      data-delay="0.3"
    >
      <input
        type="password"
        name="password"
        placeholder="Enter password"
        class="text-foreground placeholder:text-foreground/30 w-full px-4 py-3 text-center text-sm transition-all duration-200 outline-none"
        style="background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);"
        data-motion="focus-glow"
        autofocus
      >
      <button
        type="submit"
        class="inline-flex w-full items-center justify-center gap-2 px-7 py-3.5 text-sm font-semibold transition-all duration-200 hover:opacity-80"
        style="background: var(--primary); color: var(--primary-foreground); border-radius: var(--radius);"
        data-motion="hover-lift"
      >
        {{- section.settings.btn_label | default: 'Enter Store' -}}
      </button>
    </div>
  {%- endform -%}

  {%- # Footer note -%}
  <p
    class="text-foreground/30 mt-12 text-xs"
    data-motion="fade-up"
    data-delay="0.4"
  >
    {%- if section.settings.footer_note != blank -%}
      {{ section.settings.footer_note }}
    {%- else -%}
      &copy; {{ 'now' | date: '%Y' }}
      {{ shop.name }}. All rights reserved.
    {%- endif -%}
  </p>

  {%- # Social links -%}
  {%- if settings.social_instagram != blank or settings.social_facebook != blank or settings.social_twitter != blank -%}
    <div
      class="mt-8 flex items-center justify-center gap-4"
      data-motion="fade-up"
      data-delay="0.5"
    >
      {%- if settings.social_instagram != blank -%}
        <a
          href="{{ settings.social_instagram }}"
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground/30 hover:text-foreground transition-colors duration-200"
          aria-label="Instagram"
          data-motion="hover-scale"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
      {%- endif -%}
      {%- if settings.social_facebook != blank -%}
        <a
          href="{{ settings.social_facebook }}"
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground/30 hover:text-foreground transition-colors duration-200"
          aria-label="Facebook"
          data-motion="hover-scale"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
      {%- endif -%}
      {%- if settings.social_twitter != blank -%}
        <a
          href="{{ settings.social_twitter }}"
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground/30 hover:text-foreground transition-colors duration-200"
          aria-label="Twitter / X"
          data-motion="hover-scale"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Password",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Coming Soon"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We're working on something great. Enter the password to get early access."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Enter Store"
    },
    {
      "type": "text",
      "id": "footer_note",
      "label": "Footer Note"
    }
  ]
}
{% endschema %}
